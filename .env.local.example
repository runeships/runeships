# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Resend (transactional email)
RESEND_API_KEY=

# Admin — comma-separated list of emails granted /admin access via
# env (in addition to anyone with profiles.is_admin = true in the DB).
ADMIN_EMAILS=

# Optional: where "Talk to us about posting a task" form submissions
# land. Defaults to hello@runeships.com when unset.
TEAM_NOTIFICATION_EMAIL=

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
